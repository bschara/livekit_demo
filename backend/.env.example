# Django
DJANGO_SECRET_KEY=change-me-in-a-real-deployment
DJANGO_DEBUG=True
# For testing from another device on the LAN (e.g. a phone), add that origin
# too, e.g. http://localhost:5173,http://<this-machine's-LAN-IP>:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# LiveKit — must match the LIVEKIT_KEYS value in the root .env (see root .env.example)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-me-generate-a-real-secret
# For LAN testing (e.g. a phone), use this machine's LAN IP instead of
# localhost — a phone resolves "localhost" to itself, not this machine. Must
# match rtc.node_ip in livekit.yaml. Find your LAN IP with `hostname -I`.
LIVEKIT_WS_URL=ws://localhost:7880

# MinIO (self-hosted S3-compatible storage for recordings) — must match
# MINIO_ROOT_USER/PASSWORD in the root .env.
# MINIO_ENDPOINT is for browser-facing presigned playback URLs, loaded
# directly by a <video> tag on an HTTPS page — browsers block plain http://
# there as mixed content, so on a VPS this must be an HTTPS address (see
# deploy/nginx.conf.example's MINIO_DOMAIN block, which proxies to MinIO).
# MINIO_INTERNAL_ENDPOINT is for egress's own upload; leave it as localhost
# since egress and MinIO run on the same host — pointing it at a public
# address makes egress dial its own host's public IP, which can time out.
MINIO_ENDPOINT=http://localhost:9000
MINIO_INTERNAL_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-generate-a-real-secret
MINIO_BUCKET=recordings
