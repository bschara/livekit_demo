# Copy to .env (gitignored) before `docker compose up`.
# Format: "<key>: <secret>" — must match LIVEKIT_API_KEY/SECRET in backend/.env.
LIVEKIT_KEYS=devkey: change-me-generate-a-real-secret

# Same key/secret pair as LIVEKIT_KEYS above, but split out — the egress
# service's config needs them as separate fields rather than LIVEKIT_KEYS'
# combined "key: secret" format.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-me-generate-a-real-secret

# MinIO (self-hosted S3-compatible storage for recordings).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-generate-a-real-secret
